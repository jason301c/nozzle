{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "noEmit": true,
    "tsBuildInfoFile": ".tsconfig.test.tsbuildinfo",
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "vitest.config.ts",
    "vitest.safety.config.ts",
    "vitest.workers.config.ts"
  ]
}
